<Window x:Class="CyberSecurityChatbot_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Template for user messages -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Border Background="#3498DB" 
                    CornerRadius="10" 
                    Padding="10" 
                    Margin="5,2,20,2"
                    HorizontalAlignment="Right"
                    MaxWidth="400">
                <StackPanel>
                    <TextBlock Text="{Binding Sender}" 
                               FontWeight="Bold" 
                               Foreground="#E8F4FD" 
                               FontSize="11"/>
                    <TextBlock Text="{Binding Message}" 
                               TextWrapping="Wrap" 
                               Foreground="White" 
                               FontSize="13"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Timestamp}" 
                               Foreground="#E8F4FD" 
                               FontSize="9" 
                               TextAlignment="Right"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Template for bot messages -->
        <DataTemplate x:Key="BotMessageTemplate">
            <Border Background="#2C3E50" 
                    CornerRadius="10" 
                    Padding="10" 
                    Margin="20,2,5,2"
                    HorizontalAlignment="Left"
                    MaxWidth="400">
                <StackPanel>
                    <TextBlock Text="{Binding Sender}" 
                               FontWeight="Bold" 
                               Foreground="#4A90E2" 
                               FontSize="11"/>
                    <TextBlock Text="{Binding Message}" 
                               TextWrapping="Wrap" 
                               Foreground="White" 
                               FontSize="13"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Timestamp}" 
                               Foreground="#BDC3C7" 
                               FontSize="9" 
                               TextAlignment="Left"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Style selector template -->
        <DataTemplate x:Key="ChatMessageTemplate">
            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUserMessage}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUserMessage}" Value="False">
                                <Setter Property="ContentTemplate" Value="{StaticResource BotMessageTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E3A6F" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#4A90E2" 
                           VerticalAlignment="Center"
                           Text="╔══╗╔══╗╔╗─╔╗╔═══╗╔═══╗&#10;║╔╗║╚╣╠╝║║─║║║╔══╝║╔══╝&#10;║╚╝╚╗─║║─║╚═╝║║╚══╗║╚══╗&#10;║╔═╗║─║║─║╔═╗║║╔══╝║╔══╝&#10;║╚═╝║╔╣╠╗║║─║║║╚══╗║╚══╗&#10;╚═══╝╚══╝╚╝─╚╝╚═══╝╚═══╝"/>

                <TextBlock FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"
                           Text="Cybersecurity Awareness Bot"
                           Margin="15,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Chat">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="ChatMessagesListBox" 
                                 Background="#F8F9FA"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 ItemTemplate="{StaticResource ChatMessageTemplate}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="MessageTextBox" 
                                 Grid.Column="0"
                                 Height="35"
                                 Margin="0,5,5,5"
                                 Padding="5"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 TextWrapping="Wrap"/>

                        <Button x:Name="SendButton" 
                                Grid.Column="1"
                                Width="80"
                                Height="35"
                                Margin="5,5,0,5"
                                Content="Send"
                                Background="#3498DB"
                                Foreground="White"
                                FontWeight="Bold"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Task Assistant">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Add Task Section -->
                    <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="Add New Task" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Title:" Margin="0,5,10,5" VerticalAlignment="Center"/>
                                <TextBox x:Name="TaskTitleTextBox" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="30"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" Margin="0,5,10,5" VerticalAlignment="Center"/>
                                <TextBox x:Name="TaskDescriptionTextBox" Grid.Row="1" Grid.Column="1" Margin="0,5" Height="30"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Reminder:" Margin="0,5,10,5" VerticalAlignment="Center"/>
                                <TextBox x:Name="TaskReminderTextBox" Grid.Row="2" Grid.Column="1" Margin="0,5" Height="30"/>

                                <Button x:Name="AddTaskButton" Grid.Row="3" Grid.Column="1" Content="Add Task" 
                                        Background="#27AE60" Foreground="White" FontWeight="Bold" 
                                        Height="35" Margin="0,5,0,0" HorizontalAlignment="Right" Width="100"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Task List -->
                    <Border Grid.Row="2" Background="#F8F9FA" Padding="10" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Your Tasks" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <ListBox x:Name="TasksListBox" Grid.Row="1" 
                                     Background="White" BorderBrush="#BDC3C7" BorderThickness="1">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10"/>
                                        <Setter Property="Margin" Value="0,1,0,0"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button x:Name="MarkCompleteButton" Content="Mark Complete" 
                                        Background="#3498DB" Foreground="White" FontWeight="Bold"
                                        Width="120" Height="30" Margin="0,0,10,0"/>
                                <Button x:Name="DeleteTaskButton" Content="Delete Task" 
                                        Background="#E74C3C" Foreground="White" FontWeight="Bold"
                                        Width="120" Height="30"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button x:Name="StartQuizButton" Content="Start Quiz" 
                                Background="#27AE60" Foreground="White" FontWeight="Bold"
                                Width="120" Height="35" Margin="0,0,10,0"/>
                        <Button x:Name="ResetQuizButton" Content="Reset Quiz" 
                                Background="#95A5A6" Foreground="White" FontWeight="Bold"
                                Width="120" Height="35"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F8F9FA" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="QuestionNumberText" Text="Question 1 of 11" FontWeight="Bold" FontSize="12" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="QuestionTextBlock" Text="Click 'Start Quiz' to begin" FontSize="14" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="#F8F9FA" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                        <StackPanel x:Name="OptionsStackPanel">
                            <RadioButton x:Name="OptionA" Content="A" Margin="0,3" GroupName="QuizOptions" Checked="OptionSelected"/>
                            <RadioButton x:Name="OptionB" Content="B" Margin="0,3" GroupName="QuizOptions" Checked="OptionSelected"/>
                            <RadioButton x:Name="OptionC" Content="C" Margin="0,3" GroupName="QuizOptions" Checked="OptionSelected"/>
                            <RadioButton x:Name="OptionD" Content="D" Margin="0,3" GroupName="QuizOptions" Checked="OptionSelected"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#E8F4FD" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="FeedbackTextBlock" Text="" Foreground="#2C3E50" TextWrapping="Wrap"/>
                                <Button x:Name="NextQuestionButton" Content="Next Question" 
                                        Background="#3498DB" Foreground="White" FontWeight="Bold"
                                        Width="120" Height="30" Margin="0,10,0,0" HorizontalAlignment="Right" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#2C3E50" Padding="10" CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ScoreTextBlock" Text="Score: 0/0" Foreground="White" FontWeight="Bold"/>
                                <Button x:Name="FinalResultsButton" Grid.Column="1" Content="Show Results" 
                                        Background="#F39C12" Foreground="White" FontWeight="Bold"
                                        Width="120" Height="30" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border x:Name="FinalResultsBorder" Grid.Row="4" Background="#27AE60" Padding="15" CornerRadius="5" Margin="0,15,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="FinalScoreText" Text="" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            <TextBlock x:Name="FinalMessageText" Text="" Foreground="White" FontSize="14" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button x:Name="RefreshLogButton" Content="Refresh Log" 
                                Background="#3498DB" Foreground="White" FontWeight="Bold"
                                Width="120" Height="35" Margin="0,0,10,0"/>
                        <Button x:Name="ShowMoreLogButton" Content="Show More" 
                                Background="#2C3E50" Foreground="White" FontWeight="Bold"
                                Width="120" Height="35" Visibility="Collapsed"/>
                    </StackPanel>

                    <ListBox x:Name="LogListBox" Grid.Row="1" 
                             Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                             FontFamily="Consolas" FontSize="12">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0,1,0,0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <TextBlock Grid.Row="2" Text="Log entries are automatically recorded" 
                               Foreground="#7F8C8D" FontSize="11" Margin="0,10,0,0" TextAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#2C5282" Padding="5">
            <TextBlock x:Name="StatusTextBlock" 
                       Text="Ready" 
                       Foreground="#B0C4DE"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>