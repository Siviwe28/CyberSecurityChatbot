<Window x:Class="CyberSecurityChatbot_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Template for user messages (right-aligned, blue) -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Border Background="#3498DB" 
                    CornerRadius="10" 
                    Padding="10" 
                    Margin="5,2,20,2"
                    HorizontalAlignment="Right"
                    MaxWidth="400">
                <StackPanel>
                    <TextBlock Text="{Binding Sender}" 
                               FontWeight="Bold" 
                               Foreground="#E8F4FD" 
                               FontSize="11"/>
                    <TextBlock Text="{Binding Message}" 
                               TextWrapping="Wrap" 
                               Foreground="White" 
                               FontSize="13"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Timestamp}" 
                               Foreground="#E8F4FD" 
                               FontSize="9" 
                               TextAlignment="Right"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Template for bot messages (left-aligned, dark gray) -->
        <DataTemplate x:Key="BotMessageTemplate">
            <Border Background="#2C3E50" 
                    CornerRadius="10" 
                    Padding="10" 
                    Margin="20,2,5,2"
                    HorizontalAlignment="Left"
                    MaxWidth="400">
                <StackPanel>
                    <TextBlock Text="{Binding Sender}" 
                               FontWeight="Bold" 
                               Foreground="#4A90E2" 
                               FontSize="11"/>
                    <TextBlock Text="{Binding Message}" 
                               TextWrapping="Wrap" 
                               Foreground="White" 
                               FontSize="13"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Timestamp}" 
                               Foreground="#BDC3C7" 
                               FontSize="9" 
                               TextAlignment="Left"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Style selector template -->
        <DataTemplate x:Key="ChatMessageTemplate">
            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUserMessage}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUserMessage}" Value="False">
                                <Setter Property="ContentTemplate" Value="{StaticResource BotMessageTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#1E3A6F" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <!-- ASCII Art -->
                <TextBlock FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#4A90E2" 
                           VerticalAlignment="Center"
                           Text="╔══╗╔══╗╔╗─╔╗╔═══╗╔═══╗&#10;║╔╗║╚╣╠╝║║─║║║╔══╝║╔══╝&#10;║╚╝╚╗─║║─║╚═╝║║╚══╗║╚══╗&#10;║╔═╗║─║║─║╔═╗║║╔══╝║╔══╝&#10;║╚═╝║╔╣╠╗║║─║║║╚══╗║╚══╗&#10;╚═══╝╚══╝╚╝─╚╝╚═══╝╚═══╝"/>

                <!-- Title -->
                <TextBlock FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"
                           Text="Cybersecurity Awareness Bot"
                           Margin="15,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Messages ListBox with scrolling -->
            <ScrollViewer Grid.Row="0" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ListBox x:Name="ChatMessagesListBox" 
                         Background="#F8F9FA"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         ItemTemplate="{StaticResource ChatMessageTemplate}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </ScrollViewer>

            <!-- Input Area -->
            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox" 
                         Grid.Column="0"
                         Height="35"
                         Margin="0,5,5,5"
                         Padding="5"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         TextWrapping="Wrap"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Width="80"
                        Height="35"
                        Margin="5,5,0,5"
                        Content="Send"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="Bold"/>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#2C5282" Padding="5">
            <TextBlock x:Name="StatusTextBlock" 
                       Text="Ready" 
                       Foreground="#B0C4DE"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>